# PRODUCAO: defina as duas variaveis abaixo (a app bloqueia o login sem elas).
# A chave anon/publishable NAO e secreta (protegida por RLS).
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_publishable

# DEMONSTRACAO sem backend: habilite explicitamente (nunca liga automaticamente).
# Com Supabase configurado acima, esta flag e ignorada (o backend real tem prioridade).
VITE_ENABLE_DEMO_MODE=false
