# Build do site de DEMONSTRAÇÃO (projeto Cloudflare Pages separado). NÃO usar em produção.
# Copie para as variáveis de ambiente do projeto Pages "demo" — não comitar valores reais.
VITE_DEMO_MODE=true
VITE_SUPABASE_URL=https://SEU_PROJETO_DEMO.supabase.co
VITE_SUPABASE_ANON_KEY=ANON_KEY_DO_PROJETO_DEMO
# Mantém o modo mock offline desligado: a demo usa um Supabase real (porém isolado), não dados em memória.
VITE_ENABLE_DEMO_MODE=false

# ── Higiene obrigatória da conversa (alerta/bloqueio por responsável e nome) ──
# Data de CORTE em ISO 8601 ESTRITO (YYYY-MM-DD ou com hora+fuso). Conversa criada a
# partir daqui é "nova" e bloqueia o envio no dia 1; conversa anterior só alerta durante
# VITE_HIGIENE_DIAS_ADAPTACAO (janela do mutirão) e bloqueia depois.
# Vazio = usa CORTE_PADRAO versionado em src/config/higiene.ts.
# ATENÇÃO: formato brasileiro (01/09/2026) é REJEITADO de propósito — new Date() o leria
# como 9 de janeiro e moveria o corte sem avisar.
VITE_HIGIENE_CORTE_ISO=
VITE_HIGIENE_DIAS_ADAPTACAO=7
