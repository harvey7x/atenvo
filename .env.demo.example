# Build do site de DEMONSTRAÇÃO (projeto Cloudflare Pages separado). NÃO usar em produção.
# Copie para as variáveis de ambiente do projeto Pages "demo" — não comitar valores reais.
VITE_DEMO_MODE=true
VITE_SUPABASE_URL=https://SEU_PROJETO_DEMO.supabase.co
VITE_SUPABASE_ANON_KEY=ANON_KEY_DO_PROJETO_DEMO
# Mantém o modo mock offline desligado: a demo usa um Supabase real (porém isolado), não dados em memória.
VITE_ENABLE_DEMO_MODE=false
